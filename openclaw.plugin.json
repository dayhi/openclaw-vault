{
  "id": "openclaw-vault",
  "name": "OpenClaw Vault",
  "description": "Mask and restore secrets for provider HTTP and SSE traffic.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "proxy_port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "default": 19100
      },
      "secrets_baseurls": {
        "type": "object",
        "default": {},
        "additionalProperties": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
